{
  "name": "harbor-console",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Harbor Console — observability + control-plane SvelteKit SPA; a Protocol client of the Harbor Runtime.",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "stylelint \"src/**/*.{css,svelte}\" && eslint . && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.14.0",
    "eslint-plugin-svelte": "^2.46.0",
    "fake-indexeddb": "^6.0.0",
    "globals": "^14.0.0",
    "jsdom": "^25.0.0",
    "postcss-html": "^1.7.0",
    "stylelint": "^16.10.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "@skeletonlabs/skeleton": "^3.0.0"
  }
}
