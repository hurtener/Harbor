web/console/blob-report/
web/console/.playwright/

# Staged Console build embedded by `harbor console` (Phase 73m / D-129).
# `make console-build` copies the SvelteKit static bundle into
# cmd/harbor/consoledist/; that bundle is a build artifact and is NOT
# committed (CLAUDE.md §13). Only the committed `.gitkeep` keeps the
# directory present so `//go:embed` works on a bare checkout — when no
# `index.html` is embedded, `harbor console` serves a synthesized
# "run make console-build" placeholder page.
cmd/harbor/consoledist/*
!cmd/harbor/consoledist/.gitkeep

# Frontend artifacts
node_modules/
.npm/

# Tooling
.tool-versions

# Playwright MCP scratch (per-session screenshots + accessibility snapshots)
.playwright-mcp/

# Tmp
*.tmp
.tmp/
tmp/

# Local agent scratch space — Claude Code worktrees, scheduled-task locks,
# etc. These are per-clone local state and must never be tracked. A past
# agent ran `git add` in the main checkout and committed 34 worktree
# directories as gitlinks; this rule + the untracking in the same commit
# (Wave 9 §17.5 audit) closes that.
.claude/
.commandcode/
