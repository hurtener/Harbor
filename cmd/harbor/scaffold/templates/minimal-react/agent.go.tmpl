// Package {{.GoPackageName}} implements a Harbor agent named "{{.Name}}".
//
// This file is the entry point for your agent's logic. The scaffolded
// EchoAgent is a placeholder — replace its body with calls to your
// tools, planner, or LLM client.
//
// EchoAgent implements the public harbortest.Agent interface, so
// agent_test.go exercises it via harbortest.RunOnce out of the box.
// Once your real agent is wired, point the test at it the same way.
{{- if or .BuiltIns .CustomTools}}
//
// RegisterTools wires every tool declared in harbor.yaml — both the
// opt-in built-ins (tools.built_in) and the operator-defined custom
// tools (tools.custom) — onto the supplied tools.ToolCatalog. Call it
// from your binary's bootstrap path BEFORE you hand the catalog to the
// runtime (the runtime does NOT auto-discover; the wiring is
// intentionally explicit).
{{- end}}
package {{.GoPackageName}}

import (
	"context"
	"fmt"

	"github.com/hurtener/Harbor/harbortest"
{{- if or .BuiltIns .CustomTools}}
	"github.com/hurtener/Harbor/internal/tools"
{{- end}}
{{- if .BuiltIns}}
	"github.com/hurtener/Harbor/internal/tools/builtin"
{{- end}}
{{- if .CustomTools}}
	"github.com/hurtener/Harbor/internal/tools/drivers/inproc"

	customtools "github.com/example/{{.Name}}/tools"
{{- end}}
)

// EchoAgent is the scaffolded example. It echoes whatever input it
// receives. Use it as a template for your own Agent implementations.
type EchoAgent struct{}

// Compile-time check that EchoAgent satisfies harbortest.Agent.
var _ harbortest.Agent = (*EchoAgent)(nil)

// Run implements harbortest.Agent. Replace the body with your agent's
// real logic — typically a planner step, a flow invocation, or a
// hand-rolled call sequence over your tool catalog.
func (a *EchoAgent) Run(ctx context.Context, input any) (any, error) {
	if err := ctx.Err(); err != nil {
		return nil, fmt.Errorf("echo agent: %w", err)
	}
	return input, nil
}
{{- if or .BuiltIns .CustomTools}}

// RegisterTools wires every tool declared in harbor.yaml onto cat.
// Generated by `harbor scaffold` from your harbor.yaml; rerunning
// scaffold with --patch updates this function's surface when you
// add new entries (existing tool stubs in tools/ are preserved).
func RegisterTools(cat tools.ToolCatalog) error {
{{- if .BuiltIns}}
	if err := builtin.Register(cat, []string{
{{- range .BuiltIns}}
		"{{.}}",
{{- end}}
	}); err != nil {
		return fmt.Errorf("register built-ins: %w", err)
	}
{{- end}}
{{- range .CustomTools}}
	if err := inproc.RegisterFunc[customtools.{{.GoIdent}}Input, customtools.{{.GoIdent}}Output](
		cat,
		"{{.Name}}",
		customtools.{{.GoIdent}},
		tools.WithDescription({{.Description | printf "%q"}}),
	); err != nil {
		return fmt.Errorf("register custom tool %q: %w", "{{.Name}}", err)
	}
{{- end}}
	return nil
}
{{- end}}
